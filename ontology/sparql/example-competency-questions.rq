# Example SPARQL queries for DFO Salmon Ontology competency questions
# These are placeholder queries to demonstrate the structure

# Query 1: Find all stock status zones
PREFIX gcdfo: <https://w3id.org/gcdfo/salmon#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?statusZone ?label ?definition WHERE {
  ?statusZone a gcdfo:StockStatusZone ;
              rdfs:label ?label ;
              rdfs:comment ?definition .
}

# Query 2: Find all survey events with their protocols
PREFIX gcdfo: <https://w3id.org/gcdfo/salmon#>
PREFIX dwc: <http://rs.tdwg.org/dwc/terms/>

SELECT ?event ?protocol ?date WHERE {
  ?event a gcdfo:SurveyEvent ;
         dwc:samplingProtocol ?protocol ;
         dwc:eventDate ?date .
}

# Query 3: Find management units and their conservation units
PREFIX gcdfo: <https://w3id.org/gcdfo/salmon#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?managementUnit ?conservationUnit WHERE {
  ?managementUnit a gcdfo:ManagementUnit ;
                  gcdfo:hasMember ?conservationUnit .
  ?conservationUnit a gcdfo:ConservationUnit .
}
