@prefix gcdfo:    <https://w3id.org/gcdfo/salmon#> .
@prefix bfo:     <http://purl.obolibrary.org/obo/BFO_> .
@prefix iao:     <http://purl.obolibrary.org/obo/IAO_> .
@prefix odo:     <http://purl.dataone.org/odo/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dqv:     <http://www.w3.org/ns/dqv#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix sosa:    <http://www.w3.org/ns/sosa/> .
@prefix iop:     <https://w3id.org/iadopt/ont/> .
@prefix schema:  <https://schema.org/> .
@prefix vann:    <http://purl.org/vocab/vann/> .
@prefix dwc:     <http://rs.tdwg.org/dwc/terms/> .
@prefix dwciri:  <http://rs.tdwg.org/dwc/iri/> .
@prefix unit:    <http://qudt.org/vocab/unit/> .
@prefix qudt:    <http://qudt.org/schema/qudt/> .
@prefix qudtunit: <http://qudt.org/vocab/unit/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix smn:     <https://w3id.org/smn/> .
@prefix oa:      <http://www.w3.org/ns/oa#> .
@prefix envo:    <http://purl.obolibrary.org/obo/ENVO_> .
@prefix org:     <http://www.w3.org/ns/org#> .
@prefix :        <https://w3id.org/gcdfo/salmon#> .
@prefix quantitykind: <http://qudt.org/vocab/quantitykind/> .
@prefix wspview: <https://w3id.org/gcdfo/salmon/views/wsp-composite-escapement#> .

<https://w3id.org/gcdfo/salmon/views/wsp-composite-escapement> a owl:Ontology ;
  dcterms:title "DFO WSP composite-escapement metamodel view"@en ;
  dcterms:description "Non-normative view that links canonical WSP output CSV variables to ontology terms and gathers WildSalmonPolicyTheme terms for colleague review."@en ;
  rdfs:comment "Authoritative term definitions remain in https://w3id.org/gcdfo/salmon. This file is a publication/support view derived from Issue #180 source links and current SPSR semantic dictionary artifacts."@en ;
  dcterms:created "2026-03-17"^^xsd:date ;
  dcterms:modified "2026-03-17"^^xsd:date ;
  owl:imports <https://w3id.org/gcdfo/salmon> ;
  dcterms:source <https://github.com/dfo-pacific-science/salmon-population-summary-repository/issues/180#issuecomment-3862405022>, <https://raw.githubusercontent.com/sos-program/Approved-WSP-Statuses/master/OUTPUT/Retrospective_RapidStatus_Results_Approved.csv>, <https://raw.githubusercontent.com/sos-program/Approved-WSP-Statuses/master/OUTPUT/Retrospective_RapidStatus_Results_Approved_VariableDescriptions.csv>, <https://github.com/dfo-pacific-science/salmon-population-summary-repository/blob/master/data_demo/SDP_Templates/wsp_column_dictionary.csv> ;
  prov:wasDerivedFrom <https://github.com/dfo-pacific-science/salmon-population-summary-repository/issues/180> .

#################################################################
# View-local classes and mapping properties
#################################################################

wspview:SourceVariable a owl:Class ;
  rdfs:label "WSP source variable"@en ;
  rdfs:comment "A variable name from the canonical Approved-WSP-Statuses output CSV files."@en .

wspview:mappedTerm a owl:ObjectProperty .
wspview:mappedProperty a owl:ObjectProperty .
wspview:mappedEntity a owl:ObjectProperty .
wspview:mappedUnit a owl:ObjectProperty .
wspview:mappedConstraint a owl:ObjectProperty .
wspview:mappedMethod a owl:ObjectProperty .

wspview:sourceCsv a owl:AnnotationProperty .
wspview:mappingSource a owl:AnnotationProperty .
wspview:mappingStatus a owl:AnnotationProperty .
wspview:legacyIri a owl:AnnotationProperty .
wspview:notes a owl:AnnotationProperty .

#################################################################
# Collections: WSP theme terms + CSV-aligned ontology terms
#################################################################

wspview:WildSalmonPolicyThemeTerms a skos:Collection ;
  skos:prefLabel "Terms marked with gcdfo:WildSalmonPolicyTheme"@en ;
  skos:member :BenchmarkLevelScheme,
    :BiologicalBenchmarkAndIndicatorScheme,
    :IntegratedStatusOutcomeScheme,
    :PolicyFrameworkScheme,
    :RapidStatusConfidenceScheme,
    :RapidStatusMetricScheme,
    :StockStatusZoneScheme,
    :WSPBiologicalStatusZoneScheme,
    :WSPOutputVariableScheme,
    gcdfo:AbsoluteAbundanceMetricStatus,
    gcdfo:AbundanceDataType,
    gcdfo:AbundancePercentileMetric,
    gcdfo:AbundancePercentileMetricStatus,
    gcdfo:AmberZone,
    gcdfo:BenchmarkRatioMetric,
    gcdfo:ConfidenceCategory,
    gcdfo:ConservationUnit,
    gcdfo:ConservationUnitName,
    gcdfo:GenerationalAverageAbundance,
    gcdfo:GreenZone,
    gcdfo:IntegratedStatusAmberGreen,
    gcdfo:IntegratedStatusBinary,
    gcdfo:IntegratedStatusCollapsedCode,
    gcdfo:IntegratedStatusDataDeficient,
    gcdfo:IntegratedStatusFiveCategoryAlias,
    gcdfo:IntegratedStatusNotRed,
    gcdfo:IntegratedStatusOutcome,
    gcdfo:IntegratedStatusRaw,
    gcdfo:IntegratedStatusRawCode,
    gcdfo:IntegratedStatusRedAmber,
    gcdfo:IntegratedStatusThreeCategory,
    gcdfo:IntegratedStatusUndetermined,
    gcdfo:LongTermTrendMetric,
    gcdfo:LongTermTrendMetricStatus,
    gcdfo:LowerBenchmark,
    gcdfo:LowerBiologicalBenchmark,
    gcdfo:PercentChangeMetric,
    gcdfo:PercentChangeMetricStatus,
    gcdfo:PolicyFramework,
    gcdfo:ProbabilityDeclineBelowLowerBenchmarkMetric,
    gcdfo:ProbabilityDeclineBelowLowerBenchmarkMetricStatus,
    gcdfo:RapidStatusConfidenceHigh,
    gcdfo:RapidStatusConfidenceLow,
    gcdfo:RapidStatusConfidenceMedium,
    gcdfo:RapidStatusMetric,
    gcdfo:RapidStatusScoreMetric,
    gcdfo:RedZone,
    gcdfo:RelativeAbundanceMetricStatus,
    gcdfo:RelativeSpawnerAbundance,
    gcdfo:RelativeSpawnerAbundanceChange,
    gcdfo:RelativeSpawnerAbundancePercentile,
    gcdfo:RelativeSpawnerAbundanceTrend,
    gcdfo:RelativeWildSpawnerAbundance,
    gcdfo:RelativeWildSpawnerAbundanceChange,
    gcdfo:RelativeWildSpawnerAbundancePercentile,
    gcdfo:RelativeWildSpawnerAbundanceTrend,
    gcdfo:ReturnYear,
    gcdfo:SpawnerAbundance,
    gcdfo:SpawnerAbundanceChange,
    gcdfo:SpawnerAbundancePercentile,
    gcdfo:SpawnerAbundanceTrend,
    gcdfo:Species,
    gcdfo:UpperBenchmark,
    gcdfo:UpperBiologicalBenchmark,
    gcdfo:WSPBiologicalStatusZone,
    gcdfo:WSPOutputVariable,
    gcdfo:WSPRapidStatus,
    gcdfo:WSPRapidStatusAlgorithmThreshold,
    gcdfo:WSPRapidStatusAssessmentMethod,
    gcdfo:WildSalmonPolicy,
    gcdfo:WildSalmonPolicyTheme,
    gcdfo:conservationUnitOf,
    gcdfo:hasConservationUnit,
    smn:Deme,
    smn:MetricBenchmark,
    smn:NaturalOrigin,
    smn:Population,
    smn:demeOf,
    smn:hasDeme,
    smn:hasPopulation,
    smn:populationOf .

wspview:CsvAlignedOntologyTerms a skos:Collection ;
  skos:prefLabel "Ontology terms explicitly referenced by WSP CSV semantic mappings"@en ;
  skos:member gcdfo:ConfidenceCategory,
    gcdfo:ConservationUnit,
    gcdfo:LowerBenchmark,
    gcdfo:LowerBiologicalBenchmark,
    gcdfo:UpperBenchmark,
    gcdfo:UpperBiologicalBenchmark,
    gcdfo:WSPRapidStatus,
    smn:NaturalOrigin,
    smn:ObservedRateOrAbundance .

#################################################################
# Canonical source CSV variables and their current semantic mappings
#################################################################

wspview:var_CU_ID a wspview:SourceVariable ;
  rdfs:label "CU_ID"@en ;
  dcterms:description "Unique and standardized identifier for each Pacific salmon Conservation Unit (CU)"@en ;
  wspview:sourceCsv <https://raw.githubusercontent.com/sos-program/Approved-WSP-Statuses/master/OUTPUT/Retrospective_RapidStatus_Results_Approved.csv> ;
  wspview:mappingSource <https://github.com/dfo-pacific-science/salmon-population-summary-repository/blob/master/data_demo/SDP_Templates/wsp_column_dictionary.csv> ;
  wspview:mappingStatus "unmapped-in-current-wsp_column_dictionary" ;
  wspview:notes "No explicit ontology mapping is currently asserted for this source variable in data_demo/SDP_Templates/wsp_column_dictionary.csv."@en .

wspview:var_Species a wspview:SourceVariable ;
  rdfs:label "Species"@en ;
  dcterms:description "Species of salmon"@en ;
