  wspview:mappedProperty quantitykind:Count ;
  wspview:mappedEntity gcdfo:ConservationUnit ;
  wspview:mappedUnit unit:NUM ;
  wspview:mappedConstraint smn:NaturalOrigin ;
  wspview:legacyIri "https://w3id.org/gcdfo/salmon#NaturalOrigin" ;
  wspview:mappingStatus "mapped" .

